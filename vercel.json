{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "ALLOWED_ORIGINS": "https://sivilize-hub-pro.vercel.app,https://sivilize-frontend.vercel.app"
  },
  "crons": [
    {
      "path": "/ping",
      "schedule": "*/5 * * * *"
    }
  ]
}
